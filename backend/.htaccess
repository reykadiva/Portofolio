# ============================================================
# .htaccess — Portfolio Backend
# Apache mod_rewrite + Security Headers
# ============================================================

Options -Indexes
RewriteEngine On

# Blokir akses langsung ke folder includes/
RewriteRule ^includes/ - [F,L]

# Blokir akses ke file SQLite database
RewriteRule \.db$ - [F,L]

# Security headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "DENY"
Header always set X-XSS-Protection "1; mode=block"
